{
  "name": "three-backrooms",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "bake:arms": "node scripts/bake-fps-arms.mjs",
    "dev": "vite --host 127.0.0.1",
    "prebuild": "node scripts/check-encoding.mjs src app.html",
    "build": "npm run prebuild && vite build && node scripts/make-standalone.mjs",
    "check": "node scripts/check-encoding.mjs && node scripts/check-content-expansion.mjs",
    "write:utf8": "node scripts/write-utf8.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "scratch-vm": "^5.0.300",
    "three": "0.184.0"
  },
  "devDependencies": {
    "vite": "8.0.16"
  }
}
